# ============================================================================
#  EDITORIAL HORIZONTE — Variables de entorno
#  Copia este archivo a .env (local) o configúralo en Vercel → Settings → Environment Variables
# ============================================================================

# --- Base de datos (Prisma) ---
# Local con SQLite:
DATABASE_URL="file:./db/custom.db"

# Producción con Supabase / Neon / Railway (PostgreSQL):
# DATABASE_URL="postgresql://user:password@host:5432/editorial_horizonte?schema=public"
# DIRECT_URL="postgresql://user:password@host:5432/editorial_horizonte?schema=public"

# --- App ---
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
NEXT_PUBLIC_SITE_NAME="Editorial Horizonte"

# --- Admin (demo) ---
# En producción, mover a Supabase Auth + RLS
ADMIN_EMAIL="admin@editorialhorizonte.com"
ADMIN_PASSWORD="cambia-esto-en-produccion"

# --- Pasarelas de pago (llenar al integrar) ---
MERCADOPAGO_ACCESS_TOKEN=""
MERCADOPAGO_PUBLIC_KEY=""
PAYPAL_CLIENT_ID=""
PAYPAL_CLIENT_SECRET=""
IZIPAY_MERCHANT_ID=""
IZIPAY_API_KEY=""

# --- Supabase (opcional, para producción) ---
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""
