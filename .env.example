# ============================================================================
#  EDITORIAL HORIZONTE — Variables de entorno
#  Copia este archivo a .env (local) o configúralo en Vercel → Settings → Environment Variables
# ============================================================================

# --- Base de datos (PostgreSQL) ---
# REQUERIDO para producción (Vercel). SQLite no funciona en serverless.
#
# Opción A — Supabase (gratis, recomendado):
#   1. Crea proyecto en supabase.com
#   2. SQL Editor → pega el contenido de download/editorial_horizonte_schema.sql → Run
#   3. Settings → Database → Connection string → copia la URL
#   Formato: postgresql://postgres.[ref]:[pass]@aws-0-[region].pooler.supabase.com:6543/postgres
#
# Opción B — Neon (gratis, rápido):
#   1. Crea cuenta en neon.tech
#   2. Crea proyecto → copia connection string
#   3. Ejecuta el schema SQL en su editor
#
# Opción C — Vercel Postgres:
#   1. En Vercel dashboard → Storage → Create Database → Postgres
#   2. Te da la URL automáticamente
DATABASE_URL="postgresql://user:password@host:5432/editorial_horizonte?schema=public"

# --- App ---
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
NEXT_PUBLIC_SITE_NAME="Editorial Horizonte"

# --- Admin (demo) ---
# En producción, mover a Supabase Auth + RLS
ADMIN_EMAIL="admin@editorialhorizonte.com"
ADMIN_PASSWORD="cambia-esto-en-produccion"

# --- Pasarelas de pago (llenar al integrar) ---
MERCADOPAGO_ACCESS_TOKEN=""
MERCADOPAGO_PUBLIC_KEY=""
PAYPAL_CLIENT_ID=""
PAYPAL_CLIENT_SECRET=""
IZIPAY_MERCHANT_ID=""
IZIPAY_API_KEY=""

# --- Supabase (opcional, para producción con Auth + Storage) ---
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""
